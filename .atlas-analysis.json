  "keyFeatures": [
    "Modern React Hooks API for paywall management",
    "Cross-platform support for iOS and Android",
    "User identification and attribute management",
    "Subscription status tracking and entitlements",
    "Placement-based paywall triggering with feature gating",
    "Legacy Compat SDK for React Native migrations",
    "Third-party integration support (Amplitude, Adjust, AppsFlyer, etc.)",
    "Event-driven architecture with comprehensive callbacks",
    "Preloading and performance optimization",
    "Declarative loading and error state management"
  ],
  "publicApiSurface": [
    "SuperwallProvider",
    "useSuperwall",
    "usePlacement",
    "useUser",
    "useSuperwallEvents",
    "SuperwallLoading",
